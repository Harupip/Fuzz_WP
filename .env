# Tên thư mục ứng dụng/plugin bạn đang muốn Fuzzing
# Nếu thay đổi, hãy đặt code ứng dụng đó vào trong thư mục ./target-app/
TARGET_APP_NAME=shop-demo

# Đường dẫn nhận diện ứng dụng bên trong bộ máy PHP CỦA DOCKER
# - Nếu là Plugin WP: /wp-content/plugins/<tên_plugin>/
# - Nếu là Theme WP: /wp-content/themes/<tên_theme>/
TARGET_APP_PATH=/wp-content/plugins/shop-demo/

# Các công tắc điều khiển tính năng Fuzzer
FUZZER_ENABLE_UOPZ=1
FUZZER_ENABLE_PCOV=0   # (Sẽ được phát triển ở giai đoạn sau)
