# Target plugin mounted into WordPress.
TARGET_APP_NAME=shop-demo

# Path used by the fuzzer to decide whether a stack frame belongs to the target.
TARGET_APP_PATH=/wp-content/plugins/shop-demo/

# Host-side source path. This can point outside UOPZ_demo.
TARGET_APP_HOST_PATH=./target-app/shop-demo

# Instrumentation toggles.
FUZZER_ENABLE_UOPZ=1
FUZZER_ENABLE_PCOV=0
